# GRANDFORD — variables d'environnement
# Copier vers `.env` et remplir avec les vraies valeurs. NE JAMAIS commiter `.env`.
# Toute nouvelle clé doit être ajoutée ici (valeur factice) le sprint même — règle : .claude/rules/securite-secrets.md

# --- Supabase (publiques par design : la sécurité repose sur RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJfake-anon-key

# --- Supabase (SERVEUR SEULEMENT — jamais NEXT_PUBLIC_, jamais côté client) ---
SUPABASE_SERVICE_ROLE=eyJfake-service-role-key

# --- Web Push (VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BFakePublicVapidKey
VAPID_PRIVATE_KEY=fake-private-vapid-key
VAPID_SUBJECT=mailto:contact@example.com

# --- Courriel transactionnel (Resend : liens magiques + repli des rappels) ---
RESEND_API_KEY=re_fake_api_key

# --- Monitoring (optionnel au lancement) ---
SENTRY_DSN=

# --- Développement seulement ---
# 1 = active /demo/horaire (démo de la vue sans auth, données factices). JAMAIS en production.
GRANDFORD_DEMO=
