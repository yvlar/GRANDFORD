# GRANDFORD — variables d'environnement
# Copier vers `.env` et remplir avec les vraies valeurs. NE JAMAIS commiter `.env`.
# Toute nouvelle clé doit être ajoutée ici (valeur factice) le sprint même — règle : .claude/rules/securite-secrets.md

# --- Supabase (publiques par design : la sécurité repose sur RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJfake-anon-key

# --- Supabase (SERVEUR SEULEMENT — jamais NEXT_PUBLIC_, jamais côté client) ---
# DOIT être la MÊME valeur que le secret service-role injecté dans les Edge Functions sous
# le nom SUPABASE_SERVICE_ROLE_KEY (notify-fridge / send-reminders le lisent ainsi). Une
# divergence ⇒ l'Edge renvoie 401 et le push du frigo échoue EN SILENCE (best-effort).
SUPABASE_SERVICE_ROLE=eyJfake-service-role-key
# Optionnel : base des Edge Functions pour le push event-driven du frigo (Sprint 20).
# Vide = dérivée de NEXT_PUBLIC_SUPABASE_URL (`${url}/functions/v1`). Sans secret service-role,
# le push du frigo est simplement désactivé (no-op) — le live in-app via Realtime reste actif.
SUPABASE_FUNCTIONS_URL=

# --- Web Push (VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BFakePublicVapidKey
VAPID_PRIVATE_KEY=fake-private-vapid-key
VAPID_SUBJECT=mailto:contact@example.com

# --- Courriel transactionnel (Resend : liens magiques + repli des rappels) ---
RESEND_API_KEY=re_fake_api_key
# Expéditeur du repli courriel (Edge Function send-reminders — Sprint 7).
RESEND_FROM="GRANDFORD <rappels@exemple.com>"

# --- Monitoring (optionnel au lancement) ---
# DSN Sentry = clé publique d'ingestion (pas un secret) ; vide = SDK désactivé.
# La variante NEXT_PUBLIC_ est lue côté navigateur ; SENTRY_DSN sert au serveur/edge.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# --- Export iCal (FR-14) ---
# Clé SERVEUR SEULEMENT pour signer les tokens d'abonnement iCal (HMAC-SHA256).
# Jamais NEXT_PUBLIC_, jamais côté client. Générer avec : openssl rand -base64 32
ICAL_SECRET=fake-ical-secret-32-chars-minimum

# --- Développement seulement ---
# 1 = active /demo/horaire (démo de la vue sans auth, données factices). JAMAIS en production.
GRANDFORD_DEMO=
